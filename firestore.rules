rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Default Safety Net - Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Functions
    function isSignedIn() {
      // Return true to allow unauthenticated/custom PIN login access syncs
      return true;
    }
    
    function isValidId(id) {
      return true;
    }

    // 3. Profiles Collection Rules
    match /perfis/{perfilId} {
      allow read, write: if isSignedIn() && isValidId(perfilId);
    }

    // 4. Leads Collection Rules
    match /leads/{leadId} {
      allow read, write: if isSignedIn() && isValidId(leadId);
    }

    // 5. Alunos Collection Rules
    match /alunos/{alunoId} {
      allow read, write: if isSignedIn() && isValidId(alunoId);
    }

    // 6. Turmas Collection Rules
    match /turmas/{turmaId} {
      allow read, write: if isSignedIn() && isValidId(turmaId);
    }

    // 7. Materiais Collection Rules
    match /materiais/{materialId} {
      allow read, write: if isSignedIn() && isValidId(materialId);
    }

    // 8. Pagamentos Collection Rules
    match /pagamentos/{pagamentoId} {
      allow read, write: if isSignedIn() && isValidId(pagamentoId);
    }

    // 9. Suporte Collection Rules
    match /suporte/{suporteId} {
      allow read, write: if isSignedIn() && isValidId(suporteId);
    }

    // 10. Tarefas Collection Rules
    match /tarefas/{tarefaId} {
      allow read, write: if isSignedIn() && isValidId(tarefaId);
    }

    // 11. Certificate Templates Collection Rules
    match /certificados_templates/{templateId} {
      allow read, write: if isSignedIn() && isValidId(templateId);
    }

    // 12. Issued Certificates Collection Rules
    match /certificados_emitidos/{emitidoId} {
      allow read, write: if isSignedIn() && isValidId(emitidoId);
    }

    // 13. Pessoas Collection Rules
    match /pessoas/{pessoaId} {
      allow read, write: if isSignedIn() && isValidId(pessoaId);
    }

    // 14. Tarefas Suporte Collection Rules
    match /tarefas_suporte/{tsId} {
      allow read, write: if isSignedIn() && isValidId(tsId);
    }

    // 15. Historico/AuditLog Collection Rules
    match /historico/{histId} {
      allow read, write: if isSignedIn() && isValidId(histId);
    }

    // 16. ILGC Canais Collection Rules
    match /ilgc_canais/{canalId} {
      allow read, write: if isSignedIn() && isValidId(canalId);
    }

    // 17. ILGC Mensagens Collection Rules
    match /ilgc_mensagens/{msgId} {
      allow read, write: if isSignedIn() && isValidId(msgId);
    }

    // 18. ILGC Notificacoes Collection Rules
    match /ilgc_notificacoes/{noteId} {
      allow read, write: if isSignedIn() && isValidId(noteId);
    }

    // 19. Allowed Emails Collection Rules
    match /allowed_emails/{emailId} {
      allow read, write: if isSignedIn() && isValidId(emailId);
    }

    // 20. Custom Tags Collection Rules
    match /tags_personalizaveis/{tagId} {
      allow read, write: if isSignedIn() && isValidId(tagId);
    }

    // 21. Custom User Accounts Collection Rules (for email/password registration bypass)
    match /usuarios_credenciais/{userEmail} {
      allow read, write: if true;
    }

    // 22. Chat Geral Collection Rules
    match /chat_geral/{chatId} {
      allow read, write: if isSignedIn() && isValidId(chatId);
    }

    // 23. Modules Config Collection Rules
    match /modules/{moduleId} {
      allow read, write: if isSignedIn() && isValidId(moduleId);
    }
  }
}
