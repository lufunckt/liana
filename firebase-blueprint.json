{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "telefone": { "type": "string" },
        "email": { "type": "string" },
        "linkedin": { "type": "string" },
        "instagram": { "type": "string" },
        "origem": { "type": "string" },
        "produtoInteresse": { "type": "string" },
        "status": { "type": "string" },
        "temperatura": { "type": "string" },
        "responsavel": { "type": "string" },
        "ultimaInteracao": { "type": "string" },
        "proximoFollowUp": { "type": "string" },
        "observacoes": { "type": "string" },
        "tags": { "type": "array" }
      },
      "required": ["nome"]
    },
    "Aluno": {
      "title": "Aluno",
      "description": "A student",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "telefone": { "type": "string" },
        "email": { "type": "string" },
        "formacao": { "type": "string" },
        "turma": { "type": "string" },
        "statusAcesso": { "type": "string" },
        "statusNutror": { "type": "string" },
        "statusMRP": { "type": "string" },
        "grupoWhatsApp": { "type": "boolean" },
        "pendencias": { "type": "string" },
        "certificadoILG": { "type": "boolean" },
        "certificadoMEC": { "type": "boolean" },
        "pagamento": { "type": "string" },
        "observacoes": { "type": "string" }
      },
      "required": ["nome"]
    },
    "Turma": {
      "title": "Turma",
      "description": "A class cohort",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "formacao": { "type": "string" },
        "dataInicio": { "type": "string" },
        "dataEncerramento": { "type": "string" },
        "status": { "type": "string" },
        "links": { "type": "string" },
        "grupoWhatsApp": { "type": "string" },
        "responsavel": { "type": "string" },
        "observacoes": { "type": "string" }
      },
      "required": ["nome"]
    },
    "Material": {
      "title": "Material",
      "description": "A learning or operational material",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "tipo": { "type": "string" },
        "formacaoRelacionada": { "type": "string" },
        "linkDrive": { "type": "string" },
        "linkCanva": { "type": "string" },
        "status": { "type": "string" },
        "responsavel": { "type": "string" },
        "prazo": { "type": "string" },
        "observacoes": { "type": "string" }
      },
      "required": ["nome"]
    },
    "Pagamento": {
      "title": "Pagamento",
      "description": "Payment information",
      "type": "object",
      "properties": {
        "aluno": { "type": "string" },
        "formacao": { "type": "string" },
        "valorCombinado": { "type": "string" },
        "status": { "type": "string" },
        "vencimento": { "type": "string" },
        "comprovante": { "type": "string" },
        "observacoes": { "type": "string" },
        "responsavel": { "type": "string" }
      },
      "required": ["aluno"]
    },
    "Suporte": {
      "title": "Suporte",
      "description": "A support ticket",
      "type": "object",
      "properties": {
        "aluno": { "type": "string" },
        "formacao": { "type": "string" },
        "categoria": { "type": "string" },
        "descricao": { "type": "string" },
        "status": { "type": "string" },
        "responsavel": { "type": "string" },
        "dataAbertura": { "type": "string" },
        "dataResolucao": { "type": "string" },
        "resposta": { "type": "string" }
      },
      "required": ["aluno"]
    },
    "Tarefa": {
      "title": "Tarefa",
      "description": "An internal task",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "area": { "type": "string" },
        "responsavel": { "type": "string" },
        "prioridade": { "type": "string" },
        "prazo": { "type": "string" },
        "status": { "type": "string" },
        "observacoes": { "type": "string" }
      },
      "required": ["titulo"]
    },
    "Perfil": {
      "title": "Perfil",
      "description": "Collaborator profile details",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "cargo": { "type": "string" },
        "foto": { "type": "string" },
        "perfil": { "type": "string" },
        "linkedin": { "type": "string" },
        "instagram": { "type": "string" },
        "email": { "type": "string" },
        "telefone": { "type": "string" }
      },
      "required": ["nome", "cargo"]
    },
    "CertificateTemplate": {
      "title": "CertificateTemplate",
      "description": "A design template for certificates",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "tipo": { "type": "string" },
        "layoutVisual": { "type": "string" },
        "textoPrincipal": { "type": "string" },
        "cargaHorariaPadrao": { "type": "string" },
        "assinatura": { "type": "string" },
        "logo": { "type": "string" },
        "corPrincipal": { "type": "string" },
        "corSecundaria": { "type": "string" },
        "statusAtivo": { "type": "boolean" }
      },
      "required": ["nome"]
    },
    "IssuedCertificate": {
      "title": "IssuedCertificate",
      "description": "An issued certificate for a student",
      "type": "object",
      "properties": {
        "nomeAluno": { "type": "string" },
        "emailAluno": { "type": "string" },
        "nomeFormacao": { "type": "string" },
        "turma": { "type": "string" },
        "cargaHoraria": { "type": "string" },
        "dataConclusao": { "type": "string" },
        "dataEmissao": { "type": "string" },
        "nomeInstrutora": { "type": "string" },
        "observacoesInternas": { "type": "string" },
        "textoComplementar": { "type": "string" },
        "templateId": { "type": "string" },
        "templateNome": { "type": "string" },
        "dataGeracao": { "type": "string" },
        "status": { "type": "string" },
        "dataEnvio": { "type": "string" },
        "linkPdf": { "type": "string" },
        "responsavel": { "type": "string" }
      },
      "required": ["nomeAluno", "emailAluno", "templateId"]
    },
    "Pessoa": {
      "title": "Pessoa",
      "description": "Information about a persona (lead or student)",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "telefone": { "type": "string" },
        "tipoPessoa": { "type": "string" },
        "status": { "type": "string" },
        "temperatura": { "type": "string" },
        "produtoInteresse": { "type": "string" },
        "proximoContato": { "type": "string" }
      },
      "required": ["nome"]
    },
    "TarefaSuporte": {
      "title": "TarefaSuporte",
      "description": "A customized support task",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "status": { "type": "string" },
        "responsavel": { "type": "string" },
        "pessoaId": { "type": "string" }
      },
      "required": ["titulo"]
    },
    "IlgcCanal": {
      "title": "IlgcCanal",
      "description": "An internal communication workspace channel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "descricao": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "onlineMembers": { "type": "array" }
      },
      "required": ["id", "nome"]
    },
    "IlgcMensagem": {
      "title": "IlgcMensagem",
      "description": "A communication message or thread post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "channelId": { "type": "string" },
        "autorId": { "type": "string" },
        "autorNome": { "type": "string" },
        "avatar": { "type": "string" },
        "texto": { "type": "string" },
        "dataHora": { "type": "string" },
        "pinned": { "type": "boolean" },
        "reacoes": { "type": "array" },
        "anexos": { "type": "array" },
        "replies": { "type": "array" }
      },
      "required": ["id", "channelId", "autorNome", "texto"]
    },
    "IlgcNotificacao": {
      "title": "IlgcNotificacao",
      "description": "An operator workspace notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tipo": { "type": "string" },
        "conteudo": { "type": "string" },
        "origem": { "type": "string" },
        "dataHora": { "type": "string" },
        "lida": { "type": "boolean" },
        "channelId": { "type": "string" }
      },
      "required": ["id", "conteudo", "origem", "lida"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A system audit log for user actions",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "pessoaId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["action", "pessoaId", "timestamp"]
    },
    "AllowedEmail": {
      "title": "AllowedEmail",
      "description": "An email address allowed to access the system",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/perfis/{perfilId}": {
      "schema": { "$ref": "#/entities/Perfil" },
      "description": "Collection of all collaborator workspace profile data"
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Collection of all sales leads"
    },
    "/alunos/{alunoId}": {
      "schema": { "$ref": "#/entities/Aluno" },
      "description": "Collection of all students"
    },
    "/turmas/{turmaId}": {
      "schema": { "$ref": "#/entities/Turma" },
      "description": "Collection of all class cohorts"
    },
    "/materiais/{materialId}": {
      "schema": { "$ref": "#/entities/Material" },
      "description": "Collection of all materials"
    },
    "/pagamentos/{pagamentoId}": {
      "schema": { "$ref": "#/entities/Pagamento" },
      "description": "Collection of all payments"
    },
    "/suporte/{suporteId}": {
      "schema": { "$ref": "#/entities/Suporte" },
      "description": "Collection of all support tickets"
    },
    "/tarefas/{tarefaId}": {
      "schema": { "$ref": "#/entities/Tarefa" },
      "description": "Collection of all internal tasks"
    },
    "/certificados_templates/{templateId}": {
      "schema": { "$ref": "#/entities/CertificateTemplate" },
      "description": "Collection of learning/operational certificate templates"
    },
    "/certificados_emitidos/{emitidoId}": {
      "schema": { "$ref": "#/entities/IssuedCertificate" },
      "description": "Collection of verified issued certificates"
    },
    "/pessoas/{pessoaId}": {
      "schema": { "$ref": "#/entities/Pessoa" },
      "description": "Unified collection of platform persons (leads/students)"
    },
    "/tarefas_suporte/{tsId}": {
      "schema": { "$ref": "#/entities/TarefaSuporte" },
      "description": "Collection of specific client support actions"
    },
    "/ilgc_canais/{canalId}": {
      "schema": { "$ref": "#/entities/IlgcCanal" },
      "description": "Information on each operational workspace channel"
    },
    "/ilgc_mensagens/{msgId}": {
      "schema": { "$ref": "#/entities/IlgcMensagem" },
      "description": "Interactive workspace messages and threaded reply streams"
    },
    "/ilgc_notificacoes/{noteId}": {
      "schema": { "$ref": "#/entities/IlgcNotificacao" },
      "description": "Unified notifications collection for real-time team collaboration alerts"
    },
    "/historico/{histId}": {
      "schema": { "$ref": "#/entities/AuditLog" },
      "description": "Audit trail log records"
    },
    "/allowed_emails/{emailId}": {
      "schema": { "$ref": "#/entities/AllowedEmail" },
      "description": "Collection of allowed email addresses for platform access"
    }
  }
}
